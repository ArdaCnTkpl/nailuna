NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Custom domain (clerk.yourdomain.com) kullanıyorsan proxy kurulmalı; yoksa Clerk Dashboard'da o domain'i kaldır (docs/CLERK_CUSTOM_DOMAIN.md).
# Localhost'ta "failed to load clerk.browser.js" alıyorsan, script'i CDN'den yüklemek için .env.local'a ekle:
# NEXT_PUBLIC_CLERK_JS_URL=https://cdn.jsdelivr.net/npm/@clerk/clerk-js@5/dist/clerk.browser.js

# Clerk yönlendirmeleri (istersen değiştir)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/urun
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/urun

OPENAI_API_KEY=sk-...
